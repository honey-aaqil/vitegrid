GEMMA_API_KEY_CORE=replace_with_production_core_key
GEMMA_API_KEY_AUDIT=replace_with_independent_audit_key
GEMMA_MODEL=gemma-4
GEMMA_AUDIT_MODEL=gemma-4
# Vision tasks (Agent 5 layout review, Agent 2 style, ensemble type review).
# Any multimodal model your CORE key supports. Leave unset to use GEMMA_MODEL.
VITEGRID_VISION_MODEL=gemini-3.5-flash

# Template generation (Agent 3 "Start New", Agent 6 chat editor, inline refine).
# Leave unset to use GEMMA_MODEL.
VITEGRID_GENERATION_MODEL=gemini-3.5-flash
# PDF import pipeline. Options:
#   ensemble      - default. PyMuPDF native + heuristic classifier + Gemma type review.
#                   Uses Gemma sparingly to confirm/correct block types only.
#   ocr+ensemble  - same as ensemble but also runs RapidOCR locally to catch
#                   any text PyMuPDF missed. Slower first run (model download).
#   heuristic     - deterministic only, zero API calls. Fastest, cheapest.
#   vision        - send full pages to Gemma vision (worst for weak models).
# Scanned PDFs (no embedded text) auto-promote to ocr+ensemble.
VITEGRID_PIPELINE=ensemble
VITEGRID_DB_URL=sqlite:///./vitegrid.db
VITEGRID_UPLOAD_DIR=static/uploads
VITEGRID_ALLOW_ORIGINS=http://localhost:5173
